# Copy this file to .env and fill in real values.
# .env is gitignored -- secrets never enter version control.

OPENAI_API_KEY=sk-your-key-here

# Optional: Unsplash Access Key for recipe cover photos
# (https://unsplash.com/oauth/applications — free demo apps are fine).
# Without it, the UI falls back to local stock images.
# UNSPLASH_ACCESS_KEY=

# Optional overrides (Compose sets DATABASE_URL / MEDIA_ROOT for you)
# SECRET_KEY=dev-only-secret-change-in-production
# STORAGE_BACKEND=local
# MEDIA_ROOT=media
# S3_BUCKET=
# AWS_REGION=us-west-2
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------------------------
# Production (set these in the hosting dashboard, never in a committed file).
#
# Backend (Render):
#   DATABASE_URL     = Neon connection string (postgresql://... is fine;
#                      the app rewrites the driver and adds sslmode=require)
#   SECRET_KEY       = long random string, e.g.
#                      python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   OPENAI_API_KEY   = your OpenAI key
#   CORS_ORIGINS     = your frontend origin, e.g. https://kitchen-lab.vercel.app
#   STORAGE_BACKEND  = local (ephemeral) or s3 (+ S3_BUCKET / AWS_REGION)
#
# Frontend (Vercel):
#   NEXT_PUBLIC_API_URL = backend URL, e.g. https://kitchenlab-api.onrender.com
